# Dependencies
node_modules/

# Lockfiles — проект использует npm (package-lock.json). pnpm/yarn артефакты
# игнорируются, чтобы не плодить разные менеджеры пакетов.
pnpm-lock.yaml
pnpm-workspace.yaml
yarn.lock

# Build outputs
.next/
out/
dist/

# Synced content (generated by site/scripts/sync-content.sh)
site/content/

# Environment
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Local test files
*.local

# Python artifacts (skills/*/scripts)
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# TypeScript incremental build cache
*.tsbuildinfo
